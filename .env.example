NODE_ENV=development
HOST_UID=1000
HOST_GID=1000
NEXT_PUBLIC_API_URL=http://localhost:3333
DATABASE_URL=postgresql://cvforge:secret@postgres:5432/cvforge
REDIS_URL=redis://redis:6379
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=cvforge
MINIO_SECRET_KEY=secretminio
PUPPETEER_URL=http://puppeteer:3000
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mistral-small-2603
INTERVIEW_STT_MODEL=mistralai/voxtral-small-24b-2507
INTERVIEW_AI_MODEL=mistralai/mistral-small-2603
# Per-request ZDR (data_collection: "deny") — restricts OpenRouter routing to
# providers that advertise ZDR support. Check https://openrouter.ai/api/v1/endpoints/zdr
# ENABLE_ZDR_CHAT: set true for chat/LLM model if it supports ZDR (e.g. mistral-small does)
# ENABLE_ZDR_STT: keep false for Voxtral — it has no ZDR-capable provider on OpenRouter
ENABLE_ZDR_CHAT=false
ENABLE_ZDR_STT=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
SMTP_PROVIDER=resend
SMTP_SERVER=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=
EMAIL_FROM=CVforge <no-reply@example.com>
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_MAGIC_LINK_TTL_MINUTES=15
# Recommended default for US-009. Final product decision still pending.
AUTH_SESSION_TTL_DAYS=7
AUTH_COOKIE_NAME=cvforge_session
AUTH_SESSION_SECRET=change-me-for-production
# Optional override for the one-time first-admin bootstrap state file.
AUTH_STATE_FILE=
# Optional override for persisted draft candidatures created from offer URLs.
APPLICATIONS_STATE_FILE=

# Production routing via docker-compose.prod.yml
APP_DOMAIN=app.cvforge.local
LANDING_DOMAIN=cvforge.local
API_DOMAIN=api.cvforge.local
LETSENCRYPT_EMAIL=ops@example.com
TRAEFIK_DASHBOARD_ENABLED=false
TRAEFIK_DASHBOARD_HOST=traefik.cvforge.local
TRAEFIK_LOG_LEVEL=INFO
