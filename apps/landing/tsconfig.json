{
  "extends": "../../packages/config/tsconfig/base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@cvforge/types": [
        "../../packages/types/src/index.ts"
      ],
      "@cvforge/ui": [
        "../../packages/ui/src/index.tsx"
      ]
    }
  },
  "include": [
    ".next/types/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "tmp/cvforge-landing-next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
